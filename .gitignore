# Ignorar dados sensíveis (fontes brutas — nunca vão ao GitHub)
data/*.csv
data/*.xlsx
data/*.json

# Os JSONs gerados em frontend/public/data/ SÃO commitados (snapshot público)
!frontend/public/data/*.json

# Ignorar cache do Python e ambientes virtuais
__pycache__/
*.pyc
venv/
.venv/
.env
.streamlit/secrets.toml

# Next.js
frontend/.next/
frontend/node_modules/
frontend/.DS_Store
frontend/*.log
frontend/dist/

# General
*.log
dist/
build/
.next/
node_modules/